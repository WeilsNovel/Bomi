{
  "name": "bomi",
  "version": "0.0.0",
  "private": true,
  "description": "bomi · AI 食物识别 + 健康计划 多端协同项目（Monorepo）",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:miniapp": "pnpm --filter @bomi/miniapp dev:mp-weixin",
    "dev:admin": "pnpm --filter @bomi/admin dev",
    "dev:server": "pnpm --filter @bomi/server start:dev",
    "build:shared": "pnpm --filter @bomi/shared build",
    "build:miniapp": "pnpm --filter @bomi/miniapp build:mp-weixin",
    "build:admin": "pnpm --filter @bomi/admin build",
    "build:server": "pnpm --filter @bomi/server build",
    "build:ai": "pnpm --filter @bomi/ai build",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rimraf dist .turbo"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  }
}
