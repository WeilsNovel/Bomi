# ====================================================================
# bomi Monorepo 环境变量模板
# 用法：cp .env.example .env 后填入真实值；.env 已加入 .gitignore
# 安全约束：真实 Key 仅服务端/ai 层从 process.env 读取，禁止硬编码
# ====================================================================

# ---- 运行环境 ----
NODE_ENV=development

# ---- 服务端 ----
SERVER_PORT=3000
SERVER_CORS_ORIGIN=http://localhost:5173

# ---- JWT（auth 模块） ----
# 密钥务必在生产环境替换为强随机串
JWT_SECRET=dev-only-change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=7d

# ---- 微信小程序登录（code2session） ----
WX_APP_ID=
WX_APP_SECRET=

# ---- 短信验证码（手机号登录） ----
SMS_PROVIDER=
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=

# ---- 数据库 ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=bomi

# ---- AI 层 - 开发环境 ----
AI_API_KEY_DEV=
AI_BASE_URL_DEV=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_DEFAULT_MODEL_DEV=qwen-vl-max

# ---- AI 层 - 生产环境 ----
AI_API_KEY_PROD=
AI_BASE_URL_PROD=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_DEFAULT_MODEL_PROD=qwen-vl-max

# ---- AI 默认参数（可覆盖 shared/constants/ai.ts 的 AI_DEFAULT_PARAMS） ----
AI_DEFAULT_TEMPERATURE=0.2
AI_DEFAULT_MAX_TOKENS=2048
AI_REQUEST_TIMEOUT_MS=30000
AI_RETRY_TIMES=2
AI_RETRY_BASE_DELAY_MS=500
