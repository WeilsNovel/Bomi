# bomi 环境变量模板（复制为 .env 后填写真实值，.env 不提交 git）
# 整合方维护；密钥仅 server / ai 层从 process.env 读取，前端不持有任何 Key。

# ===== 服务端 packages/server =====
NODE_ENV=development
PORT=3000

# 数据库（PostgreSQL）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=bomi

# Redis（缓存 / 限流 / 验证码）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# 微信小程序（服务端换取 openid / session_key）
WX_APPID=
WX_SECRET=

# 短信服务（手机号登录，阿里云短信为例）
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# ===== AI 层 packages/ai =====
# 供应商：qwen | doubao | openai | claude | zhipu
AI_PROVIDER=qwen
AI_API_KEY_DEV=
AI_BASE_URL_DEV=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_DEFAULT_MODEL_DEV=qwen-vl-max
AI_API_KEY_PROD=
AI_BASE_URL_PROD=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_DEFAULT_MODEL_PROD=qwen-vl-max
